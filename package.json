{
	"name": "bun-dap-x",
	"version": "0.2.2",
	"description": "Standalone Debug Adapter Protocol server for Bun Inspector.",
	"keywords": [
		"bun",
		"debug-adapter-protocol",
		"dap",
		"debugger",
		"bun-inspector",
		"vscode",
		"nvim-dap"
	],
	"author": "korri123",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/korri123/bun-dap-x.git"
	},
	"bugs": {
		"url": "https://github.com/korri123/bun-dap-x/issues"
	},
	"homepage": "https://github.com/korri123/bun-dap-x#readme",
	"files": [
		"dist",
		"src",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"engines": {
		"bun": ">=1.3.14"
	},
	"type": "module",
	"module": "./src/index.ts",
	"bin": {
		"bun-dap-x": "./dist/bun-dap-x"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "bun build src/cli.ts --target=bun --outfile=dist/bun-dap-x && chmod +x dist/bun-dap-x",
		"start": "bun src/cli.ts",
		"check": "biome check . && bun run typecheck && bun run knip && bun run jscpd",
		"format": "biome format --write .",
		"test": "bun run build && bun test test",
		"typecheck": "tsgo --noEmit",
		"knip": "knip",
		"jscpd": "jscpd src",
		"prepack": "bun run build"
	},
	"dependencies": {
		"source-map-js": "^1.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/bun": "1.3.13",
		"@types/node": "25.6.1",
		"@typescript/native-preview": "7.0.0-dev.20260421.2",
		"jscpd": "4.2.4",
		"knip": "6.12.1",
		"typescript": "6.0.3"
	}
}
